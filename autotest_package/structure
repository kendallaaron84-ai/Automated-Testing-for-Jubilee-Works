# autotest/tables/test_case_data.py
from sqlalchemy import Column, Integer, ForeignKey, Text, String, JSON, DateTime
from ..db.database import Base

class TestCase(Base):
    __tablename__ = "test_cases"  # Standardized for Antigravity compatibility
    
    id = Column(Integer, primary_key=True, index=True)
    page_url = Column(String, ForeignKey("page.page_url"))
    
    # Antigravity/CSV Mapping
    step_name = Column(String)            # Maps to "Step"
    action_description = Column(Text)     # Maps to "Action"
    verification_criteria = Column(Text)  # Maps to "Verification"
    status = Column(String, default="pending")
    
    # Agent/Automation Fields
    test_case_type = Column(String)
    test_case_data = Column(JSON)
    test_script = Column(Text)
    script_path = Column(String)